{
  "name": "restore-terminals-color-icon",
  "displayName": "Restore Terminals (Color & Icon)",
  "description": "Spawn integrated terminals with custom colors and icons, and run commands on startup",
  "version": "1.0.1",
  "publisher": "ReinaldoJavierMenendezAlonso",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/rejamen/restore-terminals-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "restore-terminals.restoreTerminals",
        "title": "Restore Terminals"
      }
    ],
    "configuration": {
      "title": "Restore Terminals Config",
      "type": "object",
      "properties": {
        "restoreTerminals.runOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Whether or not to restore the terminals when VSCode starts up."
        },
        "restoreTerminals.keepExistingTerminalsOpen": {
          "type": "boolean",
          "default": false,
          "description": "Whether or not to keep any currently open terminals open when restoring."
        },
        "restoreTerminals.artificialDelayMilliseconds": {
          "type": [
            "number",
            "null"
          ],
          "default": 150,
          "description": "If you find restore terminals glitching out, or running some commands in the wrong window, you might want to try increasing this number to further delay the processing of actions. If you find it taking too long to open the terminal windows, you can try reducing this number, but be cautious as if it's too fast it will bug out."
        },
        "restoreTerminals.terminals": {
          "type": "array",
          "items": {
            "properties": {
              "splitTerminals": {
                "type": "array",
                "items": {
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "The name to give the terminal window"
                    },
                    "icon": {
                      "type": "string",
                      "description": "The icon to give the terminal window"
                    },
                    "commands": {
                      "type": "array",
                      "description": "The shell commands to execute when this terminal opens.",
                      "items": {
                        "properties": {
                          "type": "string",
                          "description": "A shell command to run."
                        }
                      }
                    },
                    "shouldRunCommands": {
                      "type": "boolean",
                      "description": "Whether to actually run the commands in the terminal, or just paste them there."
                    },
                    "color": {
                      "type": "string",
                      "description": "Terminal tab color (e.g., terminal.ansiRed, terminal.ansiBlue, terminal.ansiGreen)"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "glob": "^10.4.0",
    "mocha": "^10.8.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "@vscode/test-electron": "^2.3.0"
  }
}
